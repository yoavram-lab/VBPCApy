# Tooling lockfiles not under version control
uv.lock
########################################
# Python build / cache artifacts
########################################

__pycache__/
*.py[cod]
*.pyo
*.pyd

# Cython / pybind11 outputs
*.so
*.dll
*.dylib
*.o
*.out

# Octave/MEX compiled artifacts (machine-specific)
*.mex
*.mex*
*.oct

########################################
# Build and distribution directories
########################################

build/
dist/
*.egg-info/
*.egg
.eggs/

########################################
# Jupyter Notebook artifacts
########################################

.ipynb_checkpoints/
*.ipynb

########################################
# Local development clutter
########################################

# Virtual environments
.env/
.venv/
venv/
env/

# Hypothesis cache
.hypothesis/

# IDE/project settings
.vscode/
.idea/

# macOS metadata
.DS_Store

########################################
# Eigen / third-party source bundles
########################################

# If Eigen gets copied/extracted into src/
src/eigen/
src/eigen-*.tar.gz

# In-test Eigen copies
tests/**/eigen/

########################################
# Project-specific exclusions
########################################

# Retire stale paths (no longer present)
# (previously: src/Untitled.ipynb, legacy Full_Tests fixtures, parquet placeholders)

# Large local datasets and cultural reference data (keep out of git)
tools/datasets/**/*.npz
tools/datasets/**/*.zip
tools/datasets/**/*.vcf*
tools/datasets/**/*.bcf*
tools/datasets/**/*.csv
tools/datasets/**/*.txt

########################################
# Benchmark artifacts (if any)
########################################

.prof/
.cache/
/.pytest_cache/
/.mypy_cache/
/.ruff_cache/
.benchmarks/
pytest_cache/
.coverage
htmlcov/

# Legacy Octave autosave artifacts
pca_f_autosave
pca_f_autosave*

# Generated benchmark outputs (reproducible from justfile workflow)
# Stale historical runs — remove entirely; rerun analysis scripts as needed
results/

# Paper artifacts: keep text/json/bib; figures are tracked for JOSS submission
paper/*.log
